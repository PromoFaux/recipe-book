# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite file. In Docker this maps to the host-mounted data dir.
DATABASE_URL="file:/app/data/recipes.db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me-with-a-random-secret"

# App URL — must match the authorised redirect URI registered in GCP
# Local dev:  http://localhost:3000
# Production: https://recipes.yourdomain.com
AUTH_URL="http://localhost:3000"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorised redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your-client-secret"

# ── Access control ───────────────────────────────────────────────────────────
# Comma-separated Google email addresses allowed to log in
ALLOWED_EMAILS="you@gmail.com,wife@gmail.com"

# ── Cloudflare R2 backup (optional) ──────────────────────────────────────────
# S3-compatible endpoint for your R2 bucket
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=""

# R2 API token credentials (create at Cloudflare dashboard → R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Name of the R2 bucket to store backups in
R2_BUCKET_NAME=""
